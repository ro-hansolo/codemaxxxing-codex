#!/usr/bin/env bash
# cmxcdx — codexmaxxxing launcher.
#
# Thin wrapper around the forked `codex` binary that defaults to
# `-p opus` (Claude Opus 4.7 via anthroproxy). Codex talks straight to
# the merged anthroproxy binary on `127.0.0.1:6969` (the
# Anthroproxy.app menu bar app) — that single binary serves both the
# Anthropic Messages passthrough (/v1/messages) and the OpenAI
# Responses translator (/v1/responses) on one port.
#
# Until the May 2026 merge this script also auto-spawned the
# standalone `codex-anthropic-translator` binary on :7070 and tore it
# down on exit. That whole code path is gone now — the translator
# lives in the `rust-vertex-ai-proxy` workspace and ships inside the
# Anthroproxy.app bundle. If `:6969` isn't listening, launch the app
# (or run the binary directly): see CMXCDX.md.
#
# Configuration (env vars, with defaults):
#   CMXCDX_REPO     Path to the codemaxxxing-codex checkout.
#                   Defaults to the directory containing this script.
#   CMXCDX_PROFILE  Codex profile to invoke. Default `opus`. Pass `--`
#                   followed by codex args to override per invocation.
#
# Usage:
#   cmxcdx                       # runs `codex -p $CMXCDX_PROFILE`
#   cmxcdx -- exec "fix bug X"   # passes everything after `--` to codex

set -euo pipefail

# Resolve symlinks so the script can be invoked via `~/.local/bin/cmxcdx`
# and still know where its sibling repo lives. macOS `readlink` lacks
# `-f`, so we walk the link chain manually (portable across BSD + GNU).
source="${BASH_SOURCE[0]}"
while [[ -L "$source" ]]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
done
SCRIPT_DIR="$(cd -P "$(dirname "$source")/.." && pwd)"
REPO="${CMXCDX_REPO:-$SCRIPT_DIR}"
PROFILE="${CMXCDX_PROFILE:-opus}"

CODEX_BIN="$REPO/codex-rs/target/release/codex"

if [[ ! -x "$CODEX_BIN" ]]; then
    echo "cmxcdx: codex binary not found at $CODEX_BIN" >&2
    echo "  build it with: (cd $REPO/codex-rs && cargo build --release -p codex-cli)" >&2
    exit 1
fi

# Parse flag separator: anything after `--` goes verbatim to codex,
# replacing the default `-p $PROFILE`.
codex_args=("-p" "$PROFILE")
if [[ "${1:-}" == "--" ]]; then
    shift
    codex_args=("$@")
fi

exec "$CODEX_BIN" "${codex_args[@]}"
