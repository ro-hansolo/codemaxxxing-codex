#!/usr/bin/env bash
# cmxcdx-app — launch Codex Desktop wired through anthroproxy.
#
# Per openai/codex#10867 the desktop app hides the model picker for any
# custom `model_provider` unless `requires_openai_auth = true` is set,
# and even then it only shows models served by the provider's
# `GET <base_url>/models` endpoint. So this wrapper:
#
#   1. Verifies that `~/.codex/config.toml` has the workaround keys
#      configured. If they are missing it prints what to add and exits.
#   2. `open -W -a /Applications/Codex.app <workspace>` and waits for
#      the app to quit.
#
# Routing: Codex Desktop's bundled `codex` reads `~/.codex/config.toml`
# on startup and points every turn at the merged anthroproxy binary on
# `127.0.0.1:6969` (Anthroproxy.app menu bar app). That binary serves
# both /v1/messages (Anthropic passthrough) and /v1/responses (OpenAI
# Responses translator) on one port. No bundle modification, no
# codesign hacks; the notarized Codex.app is launched as-is.
#
# Until the May 2026 merge this wrapper also auto-spawned a standalone
# `codex-anthropic-translator` binary on :7070. That code path is gone
# — start Anthroproxy.app (or run its `vertex-proxy` binary directly)
# before launching the desktop. See CMXCDX.md.
#
# When the desktop asks you to log in on first launch, choose
# "API key" and enter any character (per the workaround in the issue).

set -euo pipefail

CONFIG="${CMXCDX_CONFIG:-$HOME/.codex/config.toml}"
SOURCE_APP="${CMXCDX_APP:-/Applications/Codex.app}"
# Default model catalog now lives in the rust-vertex-ai-proxy workspace
# (where the translator was migrated to). Override via CMXCDX_MODEL_CATALOG
# if your checkout lives elsewhere.
MODEL_CATALOG="${CMXCDX_MODEL_CATALOG:-$HOME/Documents/Personal/VertexAI-Anthropic-Proxy/rust-vertex-ai-proxy/anthropic-translator/data/models.json}"

workspace="${1:-$PWD}"
if [[ ! -d "$workspace" ]]; then
    echo "cmxcdx-app: workspace not found: $workspace" >&2
    exit 2
fi
workspace="$(cd "$workspace" && pwd)"

if [[ ! -d "$SOURCE_APP" ]]; then
    echo "cmxcdx-app: $SOURCE_APP not found." >&2
    echo "  Install it via: cmxcdx -- app" >&2
    exit 1
fi
if [[ ! -f "$MODEL_CATALOG" ]]; then
    echo "cmxcdx-app: model catalog file missing at $MODEL_CATALOG" >&2
    echo "  Override with CMXCDX_MODEL_CATALOG=/abs/path/models.json" >&2
    exit 1
fi

# Ensure the desktop-app workaround is configured. The picker is hidden
# without requires_openai_auth = true, and turns route to OpenAI rather
# than anthroproxy unless model_provider is set globally. Detection is
# a literal string match because we only need to catch the missing
# case, and parsing TOML in bash is its own bag of pain.
missing_keys=()
if ! grep -qE '^[[:space:]]*requires_openai_auth[[:space:]]*=[[:space:]]*true' "$CONFIG" 2>/dev/null; then
    missing_keys+=("requires_openai_auth = true (under [model_providers.anthroproxy])")
fi
if ! grep -qE '^[[:space:]]*model_provider[[:space:]]*=[[:space:]]*"anthroproxy"' "$CONFIG" 2>/dev/null; then
    missing_keys+=('model_provider = "anthroproxy" (top-level)')
fi
if ! grep -qE '^[[:space:]]*model_catalog_json[[:space:]]*=' "$CONFIG" 2>/dev/null; then
    missing_keys+=("model_catalog_json = \"$MODEL_CATALOG\" (top-level)")
fi
if (( ${#missing_keys[@]} > 0 )); then
    echo "cmxcdx-app: $CONFIG is missing the desktop-app workaround keys:" >&2
    for k in "${missing_keys[@]}"; do
        echo "  - $k" >&2
    done
    cat >&2 <<EOF

Add these blocks to $CONFIG and re-run:

    # Top-level: route every desktop turn through anthroproxy.
    model_provider = "anthroproxy"
    # Top-level: feed our claude-opus-4-7 catalog into the desktop picker.
    model_catalog_json = "$MODEL_CATALOG"

    [model_providers.anthroproxy]
    # ...your existing keys, plus:
    requires_openai_auth = true

On first launch the desktop app will prompt for an OpenAI login. Pick
"API key" and enter any character; anthroproxy ignores it and injects
real Vertex auth itself.

Docs:
  https://developers.openai.com/codex/config-reference
  https://github.com/openai/codex/issues/10867
EOF
    exit 1
fi

# Make sure anthroproxy itself is up. Without it, every desktop turn
# will fail with a connection-refused error that's annoying to debug
# from inside the desktop UI. Lightweight TCP probe — no curl, no
# external deps.
if ! nc -z 127.0.0.1 6969 >/dev/null 2>&1; then
    echo "cmxcdx-app: nothing listening on 127.0.0.1:6969" >&2
    echo "  Start Anthroproxy.app (menu bar app) or run its binary directly:" >&2
    echo "    /Applications/Anthroproxy.app/Contents/MacOS/vertex-proxy" >&2
    exit 1
fi

# Launch the original notarized Codex.app and block until it quits.
open -W -a "$SOURCE_APP" "$workspace"
